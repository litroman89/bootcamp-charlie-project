---
const { pathname } = Astro.url;

// Если путь начинается с /ru/ - меняем на /en/, и наоборот
const isRussian = pathname.startsWith('/ru');
const newPath = isRussian
    ? pathname.replace('/ru', '/en')
    : pathname.replace('/en', '/ru');
---

<div class='lang-switcher' aria-label='change language'>
    <a
        href={!isRussian ? '/en' + pathname : pathname}
        class={!isRussian ? 'active' : ''}>ENG</a
    >
    <span class='divider'>/</span>
    <a
        href={isRussian ? '/ru' + pathname : pathname}
        class={isRussian ? 'active' : ''}>РУС</a
    >
</div>

<style>
    .lang-switcher {
        display: flex;
        gap: 2px;
        font-weight: bold;
    }
    .divider {
        color: var(--color-brand-primary);
        font-size: 20px;
        font-weight: 700;
    }
    a {
        font-family: var(--font-heading);
        color: #ffffff;
        font-size: 20px;
        font-weight: 700;

        text-transform: uppercase;
    }
    a.active {
        color: var(--color-brand-primary); /* Активный цвет */
        text-decoration-line: underline;
        text-underline-position: from-font;
        text-decoration-style: solid;
    }
</style>
