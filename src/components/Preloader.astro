---
import AnimatedGrid from './AnimatedGrid.astro';
import Logo from '@/assets/icons/snake-icon-white.svg';
---

<div id='preloader'>
    <AnimatedGrid id='hero' />
    <div class='logo'>
        <a href='/' class='header__logo'>
            <Logo width={45} height={41} aria-label='go to home page' />
        </a>
    </div>

    <div class='content'>
        <div class='percent__wrap'>
            <span id='percent-display'>0</span><span class='pct__sign'>%</span>
        </div>

        <div class='bar__track'>
            <div id='bar-fill' class='bar__fill'></div>
        </div>
    </div>
</div>

<style>
    #preloader {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        overflow: hidden;
        background: var(--gradient-primary);
    }

    .logo {
        position: absolute;
        top: 30px;
        left: 50px;
        z-index: 10;
    }

    .content {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;
        width: min(560px, 80vw);
    }

    .percent__wrap {
        display: flex;
        align-items: baseline;
        gap: 4px;
        color: var(--color-text-primary);
        line-height: 1;
    }

    #percent-display {
        font-family: var(--font-heading);
        font-size: 80px;
        font-weight: 700;
        letter-spacing: -1.74px;
        text-align: right;
    }

    .pct__sign {
        font-size: 80px;
        font-weight: 700;
        font-family: var(--font-heading);
    }

    .bar__track {
        width: 100%;
        height: 20px;
        background: var(--color-text-primary);
        border-radius: 999px;
        overflow: hidden;
        position: relative;
    }

    .bar__fill {
        height: 100%;
        width: 0%;
        background: var(--color-brand-primary);
        border-radius: 999px;
        transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }
</style>

<script>
    interface Step {
        value: number;
        delay: number;
    }

    const display = document.getElementById(
        'percent-display',
    ) as HTMLSpanElement | null;
    const fill = document.getElementById('bar-fill') as HTMLDivElement | null;

    const steps: Step[] = [
        { value: 0, delay: 0 },
        { value: 54, delay: 800 },
        { value: 67, delay: 2000 },
        { value: 98, delay: 3200 },
    ];

    function animateTo(
        target: number,
        duration: number,
        onDone?: () => void,
    ): void {
        if (!display || !fill) return;

        const start: number = parseInt(display.textContent ?? '0', 10);
        const startTime: number = performance.now();

        function tick(now: number): void {
            if (!display || !fill) return;

            const elapsed: number = now - startTime;
            const progress: number = Math.min(elapsed / duration, 1);
            const eased: number = 1 - Math.pow(1 - progress, 3); 
            const current: number = Math.round(
                start + (target - start) * eased,
            );

            display.textContent = String(current);
            fill.style.width = `${current}%`;

            if (progress < 1) {
                requestAnimationFrame(tick);
            } else {
                onDone?.();
            }
        }

        requestAnimationFrame(tick);
    }

    function runSteps(index: number): void {
        if (index >= steps.length) return;

        const step: Step = steps[index];
        const nextStep: Step | undefined = steps[index + 1];

        setTimeout((): void => {
            if (nextStep) {
                const duration: number = nextStep.delay - step.delay;
                animateTo(nextStep.value, duration * 0.85, () =>
                    runSteps(index + 1),
                );
            }
        }, step.delay);
    }

    runSteps(0);
</script>
