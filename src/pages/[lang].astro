---
import type { SupportedLang } from '@/i18n/nav';
import Layout from '@/layouts/Layout.astro';
import Hero from '@/sections/Hero.astro';
import { cpaApi } from '@/services/api';

export function getStaticPaths() {
	return [{ params: { lang: 'en' } }, { params: { lang: 'ru' } }];
}

const [benefits, multiply, tasks] = await Promise.all([
	cpaApi.benefits(),
	cpaApi.multiply(),
	cpaApi.tasks(),
]);

const { lang } = Astro.params;
---

<Layout>
	<!-- <pre>{JSON.stringify(benefits, null, 2)}</pre> -->
	<Hero lang={lang as SupportedLang} />
</Layout>
