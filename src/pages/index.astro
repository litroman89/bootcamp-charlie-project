---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/sections/Hero.astro';
import MultiBenefits from '@/sections/MultiBenefits.astro';
import MultiplyWithUs from '@/sections/MultiplyWithUs.astro';
import MultyTasks from '@/sections/MultyTasks.astro';
import { cpaApi } from '@/services/api';
const [benefits, multiply, tasks] = await Promise.all([
	cpaApi.benefits(),
	cpaApi.multiply(),
	cpaApi.tasks(),
]);
---

<Layout>
	<!-- <pre>{JSON.stringify(tasks, null, 2)}</pre> -->
	<Hero />
	<MultyTasks data={tasks} />
	<MultiBenefits />
	<MultiplyWithUs />
</Layout>
