---
import { Picture } from 'astro:assets';

import snakeImage from '@/assets/img/img-hero.png';
import AnimatedGrid from '@/components/AnimatedGrid.astro';
import Container from '@/components/Container.astro';
import Header from '@/components/Header.astro';
import MainButton from '@/components/MainButton.astro';
import SocialLinks from '@/components/SocialLinks.astro';
---

<section class='hero gradient-bg'>
    <Header />
    <AnimatedGrid id='hero' />
    <div class='hero__content'>
        <Container>
            <div class='hero__text'>
                <h1 class='hero__title'>
                    PRACTICE <br /> MAKES
                    <span class='hero__title-animated'>PROFIT</span>
                </h1>
                <p class='hero__description'>
                    We provide effective solutions, tested and refined on our
                    own products and ad budgets
                </p>

                <div class='hero__button-container'>
                    <MainButton>Get in Touch</MainButton>
                </div>
            </div>
        </Container>
    </div>

    <footer class='footer'>
        <Container>
            <SocialLinks variant='hero' />
        </Container>
    </footer>

    <Picture
        src={snakeImage}
        alt='snake image'
        formats={['avif', 'webp']}
        widths={[320, 768, 1200, snakeImage.width]}
        sizes='(max-width: 320px) 320px, (max-width: 768px) 768px, 1200px'
        class='hero__image'
        fetchpriority='high'
        loading='eager'
    />
</section>

<style>
    .gradient-bg {
        background: var(--gradient-primary);
    }
    .hero {
        display: flex;
        flex-direction: column;
        padding-top: 30px;
        padding-bottom: 50px;
        height: 100dvh;
    }

    .hero__content {
        margin-top: 16vh;
        flex: 1;
        display: flex;
    }

    .hero__text {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 1;
    }

    .hero__title {
        font-family: var(--font-heading);
        color: var(--color-text-primary);
        font-size: clamp(38px, 18px + 5vw, 80px);
        font-weight: 700;
        line-height: 90%; /* 72px */
        letter-spacing: -1.742px;
        text-transform: uppercase;
    }

    .hero__title-animated {
        color: var(--color-brand-primary);
        display: inline-block;
        min-width: 100px;
        max-width: 120px;
        will-change: transform;
    }

    .hero__description {
        max-width: 536px;
        font-family: var(--font-body);
        color: var(--color-text-primary);
        font-size: clamp(16px, 14.0952px + 0.4762vw, 20px);
        font-weight: 400;
        line-height: 120%;
        margin-bottom: 30px;
    }

    .hero__button-container {
        margin-top: 30px;
    }

    @media (max-width: 768px) {
        .hero__description {
            margin-bottom: 0;
        }

        .hero__button-container {
            margin-top: 8px;
        }
    }

    .hero__image {
        position: absolute;
        max-width: clamp(436px, 191.7143px + 61.0714vw, 949px);
        height: auto;
        bottom: 0;
        right: 0px;
        pointer-events: none;
        z-index: 0;
    }
</style>

<script>
    import { revealFromBottom, revealFromLeft } from '@animations/reveal';
    import { cycleWords } from '@animations/wordCycle';

    // Elements from Bottom
    revealFromLeft(
        ['.hero__title', '.hero__description', '.hero__button-container'],
        { distance: 150 },
    );

    // Elements from Left
    revealFromBottom('.hero footer .social-link', {
        start: 'top 100%',
        delay: 0.2,
    });

    // Cycle words animation
    cycleWords('.hero__title-animated', ['PROFIT', 'GROWTH', 'SKILLS']);
</script>
