---
import { Picture } from 'astro:assets';
import { Image } from 'astro:assets';

import snakeIcon from '@/assets/icons/snake-icon-yellow.svg';
import benefitsImage from '@/assets/img/snake-benefits.png';
import Container from '@/components/Container.astro';
---

<section class='benefits'>
    <Container>
        <h2 class='benefits__title'>multi-benefits</h2>

        <h3 class='benefits__label'>
            Results can only be
            <em>guaranteed</em>
            when you control every step
        </h3>

        <div class='benefits__wrapper'>
            <p class='benefits__text'>
                That's why we've built a full-time in-house team and developed
                our own infrastructure tailored to each task — tested daily in
                the sweepstakes vertical
            </p>

            <div class='benefits__cards'>
                <ul class='benefits__list'>
                    <li class='benefit__card'>
                        We take on outsourced projects across any niche — from
                        iGaming and dating to e-commerce and recruitment
                    </li>
                    <li class='benefit__card'>
                        We deliver what has already proven effective — many
                        times over
                    </li>
                    <li class='benefit__card'>
                        We don’t learn at the client’s expense
                    </li>
                </ul>

                <Picture
                    src={benefitsImage}
                    alt='Фиолетовая змея с жёлтыми глазами и переливающейся чешуёй'
                    class='benefits__image'
                    width={390}
                    formats={['avif', 'webp', 'png']}
                />
            </div>
        </div>
    </Container>

    <!-- анимация, alt иконке не указывал так как это декоративный элемент-->
    <div class='ticker'>
        <div class='ticker__track'>
            <div class='ticker__content'>
                <span>DREAM BIG EARN BIGGER!</span>
                <Image src={snakeIcon} alt='' width={60} />
                <span>DREAM BIG EARN BIGGER!</span>
                <Image src={snakeIcon} alt='' width={60} />
            </div>

            <div class='ticker__content' aria-hidden='true'>
                <span>DREAM BIG EARN BIGGER!</span>
                <Image src={snakeIcon} alt='' width={60} />
                <span>DREAM BIG EARN BIGGER!</span>
                <Image src={snakeIcon} alt='' width={60} />
            </div>
        </div>
    </div>
</section>

<style>
    .benefits {
        position: relative;
        background: var(--gradient-primary);
        min-height: 100vh;
        padding-top: 60px;
        padding-bottom: 40px;
    }

    .benefits__title {
        text-align: right;
        font-weight: 700;
        font-size: 40px;
        line-height: 90%;
        color: var(--color-brand-primary);
    }
    em {
        font-style: normal;
        color: var(--color-brand-primary);
    }

    .benefits__label {
        margin-top: 60px;
        width: 746px;
        font-size: 50px;
        text-transform: none;
        color: var(--color-text-primary);
        line-height: 1
    }
    .benefits__wrapper {
        padding-top: 20px;
        display: flex;
        justify-content: space-between;
    }
    .benefits__text {
        color: var(--color-text-primary);
        flex-basis: 563px;
        font-size: 20px;
    }
    .benefits__content {
        flex-basis: 563px;
        font-family: var(--font-body);
    }

    .benefits__cards {
        position: relative;
        flex-basis: 563px;
    }

    .benefits__list {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 40px;
    }
    .benefit__card {
        padding: 20px 80px 20px 20px;
        border-radius: var(--radius-sm);
        background-color: var(--color-brand-secondary);
        font-size: 20px;
        line-height: 24px;
        color: var(--color-text-primary);
        font-weight: 700;
        &:hover {
            color: var(--color-text-dark);
            background-color: var(--color-brand-primary);
        }
    }

    .benefits__image {
        position: absolute;
        left: -390px;
        top: -20px;
        pointer-events: none;
        z-index: 0;
    }

    .ticker {
        position: absolute;
        bottom: 48px;
        width: 100%;
        overflow: hidden;
        border-top: 2px solid var(--color-brand-primary);
        border-bottom: 2px solid var(--color-brand-primary);
        transform: rotate(1deg);
    }

    .ticker__track {
        display: flex;
        width: max-content;
        animation: ticker 18s linear infinite;
    }

    .ticker__content {
        display: flex;
        align-items: center;
        gap: 60px;
        padding-right: 60px;
        font-size: 70px;
        font-weight: 300;
        color: var(--color-brand-primary);
        font-family: var(--font-heading);
    }

    .ticker__icon {
        font-size: 42px;
    }

    @keyframes ticker {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
</style>
